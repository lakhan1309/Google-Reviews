# Database (Neon PostgreSQL — required for Vercel)
DATABASE_URL="postgresql://user:password@host.neon.tech/reviews?sslmode=require"

# LLM provider: "gemini" or "openai" (auto-detects from keys if unset; Gemini preferred when both exist)
LLM_PROVIDER="gemini"

# Gemini
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-3.5-flash"

# OpenAI (optional if using Gemini)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Mock reviews — local dev only; leave unset or false on Vercel
USE_MOCK_REVIEWS="true"

# Auth
AUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# App URL (used for QR codes — set to your Vercel URL in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
